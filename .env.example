# LexCore + LexRadar — Environment Variables Template
# Copy to .env and customize for local development

# Application
LEXCORE_ENVIRONMENT=development
LEXCORE_LOG_LEVEL=DEBUG

# Database
LEXCORE_DATABASE_URL=postgresql+asyncpg://lexcore:lexcore_dev_password@localhost:5432/lexcore
LEXCORE_DATABASE_POOL_SIZE=10
LEXCORE_DATABASE_MAX_OVERFLOW=20

# Redis
LEXCORE_REDIS_URL=redis://localhost:6379/0
LEXCORE_REDIS_POOL_SIZE=10

# Vector Database (Qdrant)
LEXCORE_QDRANT_URL=http://localhost:6333
LEXCORE_QDRANT_API_KEY=

# Vault
LEXCORE_VAULT_ADDR=http://localhost:8200
LEXCORE_VAULT_TOKEN=dev-token-only-for-local
LEXCORE_VAULT_NAMESPACE=

# JWT
LEXCORE_JWT_SECRET=change-me-in-production
LEXCORE_JWT_ALGORITHM=HS256
LEXCORE_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
LEXCORE_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
LEXCORE_RATE_LIMIT_REQUESTS_PER_MINUTE=100
LEXCORE_RATE_LIMIT_BURST=150

# CORS
LEXCORE_CORS_ORIGINS='["*"]'
LEXCORE_ALLOWED_HOSTS='["*"]'

# Polygon (Blockchain)
LEXCORE_POLYGON_RPC_URL=https://polygon-rpc.com
LEXCORE_POLYGON_PRIVATE_KEY=
LEXCORE_POLYGON_CHAIN_ID=137

# S3
LEXCORE_S3_BUCKET_LEGAL_DOCS=lexcore-legal-docs
LEXCORE_S3_BUCKET_FILING_BUNDLES=lexradar-filing-bundles
LEXCORE_AWS_REGION=us-east-1

# Monitoring
LEXCORE_OTEL_EXPORTER_OTLP_ENDPOINT=
LEXCORE_PROMETHEUS_PORT=9090

# Feature Flags
LEXCORE_ENABLE_MCP_TOOLS=true
LEXCORE_ENABLE_INGEST_PIPELINE=true
LEXCORE_ENABLE_MONITORING=true

# Security
LEXCORE_BYOK_ENABLED=true
LEXCORE_ENCRYPTION_ALGORITHM=AES-256-GCM
