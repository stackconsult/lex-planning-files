{
  "schema_version": "v0.1.0-foundation",
  "description": "Constraint registry for LexCore + LexRadar PostgreSQL schema. All CHECK, UNIQUE, FOREIGN KEY, and NOT NULL constraints.",
  "last_updated": "2026-04-29",
  "check_constraints": [
    {"table":"tenants","name":"tenants_tier_check","expression":"tier IN ('SOLO','FIRM','ENTERPRISE')","columns":["tier"]},
    {"table":"tenants","name":"tenants_payment_status_check","expression":"payment_status IN ('TRIAL','ACTIVE','CANCELLED','PAST_DUE')","columns":["payment_status"]},
    {"table":"users","name":"users_role_check","expression":"role IN ('admin','member','viewer')","columns":["role"]},
    {"table":"roles_permissions","name":"roles_permissions_action_check","expression":"action IN ('read','write','delete','admin')","columns":["action"]},
    {"table":"roles_permissions","name":"roles_permissions_scope_check","expression":"scope IN ('tenant','workspace','user')","columns":["scope"]},
    {"table":"payment_plans","name":"payment_plans_status_check","expression":"status IN ('TRIAL','ACTIVE','CANCELLED','PAST_DUE')","columns":["status"]},
    {"table":"legal_documents","name":"legal_documents_body_of_law_check","expression":"body_of_law IN ('STATUTE','REGULATION','CASE')","columns":["body_of_law"]},
    {"table":"legal_chunks","name":"legal_chunks_chunk_type_check","expression":"chunk_type IN ('SECTION','PARAGRAPH','SENTENCE')","columns":["chunk_type"]},
    {"table":"legal_citations","name":"legal_citations_type_check","expression":"citation_type IN ('FORWARD','BACKWARD')","columns":["citation_type"]},
    {"table":"legal_citations","name":"legal_citations_citing_ne_cited","expression":"citing_document_id != cited_document_id","columns":["citing_document_id","cited_document_id"]},
    {"table":"query_cache","name":"query_cache_result_count_nonneg","expression":"result_count >= 0","columns":["result_count"]},
    {"table":"monitor_rules","name":"monitor_rules_status_check","expression":"status IN ('ACTIVE','PAUSED','ARCHIVED')","columns":["status"]},
    {"table":"monitor_alerts","name":"monitor_alerts_type_check","expression":"alert_type IN ('AMENDMENT','REPEAL','NEW')","columns":["alert_type"]},
    {"table":"research_tasks","name":"research_tasks_status_check","expression":"status IN ('PENDING','RUNNING','COMPLETED','FAILED')","columns":["status"]},
    {"table":"research_tasks","name":"research_tasks_confidence_check","expression":"confidence IS NULL OR (confidence >= 0.0 AND confidence <= 1.0)","columns":["confidence"]},
    {"table":"jurisdictions","name":"jurisdictions_coverage_check","expression":"coverage_percent >= 0.0 AND coverage_percent <= 100.0","columns":["coverage_percent"]},
    {"table":"invention_candidates","name":"invention_candidates_status_check","expression":"status IN ('DETECTED','SCORING','SCORED','DISCLOSING','DISCLOSED','FILED')","columns":["status"]},
    {"table":"invention_candidates","name":"invention_candidates_score_range_check","expression":"(novelty_score IS NULL OR (novelty_score >= 0.0 AND novelty_score <= 1.0)) AND (nonobviousness_score IS NULL OR (nonobviousness_score >= 0.0 AND nonobviousness_score <= 1.0)) AND (utility_score IS NULL OR (utility_score >= 0.0 AND utility_score <= 1.0)) AND (enablement_score IS NULL OR (enablement_score >= 0.0 AND enablement_score <= 1.0)) AND (scope_score IS NULL OR (scope_score >= 0.0 AND scope_score <= 1.0)) AND (evidence_score IS NULL OR (evidence_score >= 0.0 AND evidence_score <= 1.0)) AND (composite_score IS NULL OR (composite_score >= 0.0 AND composite_score <= 1.0))","columns":["novelty_score","nonobviousness_score","utility_score","enablement_score","scope_score","evidence_score","composite_score"]},
    {"table":"invention_candidates","name":"invention_candidates_source_type_check","expression":"source_type IN ('GitHub','Jira','Notion')","columns":["source_type"]},
    {"table":"disclosures","name":"disclosures_status_check","expression":"status IN ('DRAFT','REVIEWING','APPROVED','REJECTED','REQUESTED_CHANGES')","columns":["status"]},
    {"table":"disclosures","name":"disclosures_grounding_score_check","expression":"grounding_score IS NULL OR (grounding_score >= 0.0 AND grounding_score <= 1.0)","columns":["grounding_score"]},
    {"table":"prior_art","name":"prior_art_source_check","expression":"source IN ('USPTO','WIPO','EPO','Lens','GooglePatents','PatentScope','IPcom')","columns":["source"]},
    {"table":"prior_art","name":"prior_art_relevance_score_check","expression":"relevance_score IS NULL OR (relevance_score >= 0.0 AND relevance_score <= 1.0)","columns":["relevance_score"]},
    {"table":"blockchain_anchors","name":"blockchain_anchors_entity_type_check","expression":"entity_type IN ('INVENTION','DISCLOSURE','FILING_BUNDLE')","columns":["entity_type"]},
    {"table":"blockchain_anchors","name":"blockchain_anchors_document_hash_format","expression":"document_hash ~ '^[a-f0-9]{64}$'","columns":["document_hash"]},
    {"table":"filing_bundles","name":"filing_bundles_status_check","expression":"status IN ('DRAFT','READY','SUBMITTED','ARCHIVED')","columns":["status"]},
    {"table":"filing_bundles","name":"filing_bundles_patent_type_check","expression":"patent_type IN ('PROVISIONAL','NON_PROVISIONAL','PCT')","columns":["patent_type"]},
    {"table":"disclosures_filing_bundles","name":"disclosures_filing_bundles_role_check","expression":"role IN ('PRIMARY','SECONDARY','REFERENCE')","columns":["role"]},
    {"table":"attorney_reviews","name":"attorney_reviews_status_check","expression":"status IN ('PENDING','IN_PROGRESS','APPROVED','REJECTED','REQUESTED_CHANGES')","columns":["status"]},
    {"table":"attorney_reviews","name":"attorney_reviews_email_format","expression":"attorney_email ~ '^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$'","columns":["attorney_email"]}
  ],
  "unique_constraints": [
    {"table":"tenants","name":"tenants_email_unique","columns":["email"],"deferrable":false},
    {"table":"users","name":"users_tenant_email_unique","columns":["tenant_id","email"],"deferrable":false},
    {"table":"roles_permissions","name":"roles_permissions_tenant_user_resource_action_unique","columns":["tenant_id","user_id","resource","action"],"deferrable":false},
    {"table":"workspaces","name":"workspaces_tenant_name_unique","columns":["tenant_id","name"],"deferrable":false},
    {"table":"legal_documents","name":"legal_documents_tenant_source_citation_unique","columns":["tenant_id","source","citation"],"deferrable":false,"nulls_not_distinct":false},
    {"table":"legal_chunks","name":"legal_chunks_tenant_document_chunk_unique","columns":["tenant_id","document_id","chunk_index"],"deferrable":false},
    {"table":"legal_citations","name":"legal_citations_tenant_citing_cited_unique","columns":["tenant_id","citing_document_id","cited_document_id","citation_type"],"deferrable":false},
    {"table":"query_cache","name":"query_cache_tenant_fingerprint_unique","columns":["tenant_id","query_fingerprint"],"deferrable":false},
    {"table":"jurisdictions","name":"jurisdictions_tenant_code_unique","columns":["tenant_id","jurisdiction_code"],"deferrable":false},
    {"table":"api_keys","name":"api_keys_key_hash_unique","columns":["key_hash"],"deferrable":false},
    {"table":"disclosures_filing_bundles","name":"disclosures_filing_bundles_disclosure_bundle_unique","columns":["disclosure_id","filing_bundle_id"],"deferrable":false},
    {"table":"attorney_reviews","name":"attorney_reviews_tenant_disclosure_unique","columns":["tenant_id","disclosure_id"],"deferrable":false}
  ],
  "foreign_key_constraints": [
    {"table":"users","name":"users_tenant_id_fkey","columns":["tenant_id"],"references":"tenants","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
    {"table":"roles_permissions","name":"roles_permissions_tenant_id_fkey","columns":["tenant_id"],"references":"tenants","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
    {"table":"roles_permissions","name":"roles_permissions_user_id_fkey","columns":["user_id"],"references":"users","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
    {"table":"payment_plans","name":"payment_plans_tenant_id_fkey","columns":["tenant_id"],"references":"tenants","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
    {"table":"workspaces","name":"workspaces_tenant_id_fkey","columns":["tenant_id"],"references":"tenants","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
    {"table":"api_keys","name":"api_keys_tenant_id_fkey","columns":["tenant_id"],"references":"tenants","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
    {"table":"audit_log","name":"audit_log_tenant_id_fkey","columns":["tenant_id"],"references":"tenants","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
    {"table":"legal_documents","name":"legal_documents_tenant_id_fkey","columns":["tenant_id"],"references":"tenants","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
    {"table":"legal_chunks","name":"legal_chunks_tenant_id_fkey","columns":["tenant_id"],"references":"tenants","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
    {"table":"legal_chunks","name":"legal_chunks_document_id_fkey","columns":["document_id"],"references":"legal_documents","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
    {"table":"legal_citations","name":"legal_citations_tenant_id_fkey","columns":["tenant_id"],"references":"tenants","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
    {"table":"legal_citations","name":"legal_citations_citing_document_id_fkey","columns":["citing_document_id"],"references":"legal_documents","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
    {"table":"legal_citations","name":"legal_citations_cited_document_id_fkey","columns":["cited_document_id"],"references":"legal_documents","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
    {"table":"query_cache","name":"query_cache_tenant_id_fkey","columns":["tenant_id"],"references":"tenants","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
    {"table":"monitor_rules","name":"monitor_rules_tenant_id_fkey","columns":["tenant_id"],"references":"tenants","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
    {"table":"monitor_alerts","name":"monitor_alerts_tenant_id_fkey","columns":["tenant_id"],"references":"tenants","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
    {"table":"monitor_alerts","name":"monitor_alerts_rule_id_fkey","columns":["rule_id"],"references":"monitor_rules","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
    {"table":"monitor_alerts","name":"monitor_alerts_document_id_fkey","columns":["document_id"],"references":"legal_documents","ref_columns":["id"],"on_delete":"SET NULL","on_update":"CASCADE"},
    {"table":"research_tasks","name":"research_tasks_tenant_id_fkey","columns":["tenant_id"],"references":"tenants","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
    {"table":"research_task_documents","name":"research_task_documents_tenant_id_fkey","columns":["tenant_id"],"references":"tenants","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
    {"table":"research_task_documents","name":"research_task_documents_task_id_fkey","columns":["task_id"],"references":"research_tasks","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
    {"table":"research_task_documents","name":"research_task_documents_document_id_fkey","columns":["document_id"],"references":"legal_documents","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
    {"table":"research_task_citations","name":"research_task_citations_tenant_id_fkey","columns":["tenant_id"],"references":"tenants","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
    {"table":"research_task_citations","name":"research_task_citations_task_id_fkey","columns":["task_id"],"references":"research_tasks","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
