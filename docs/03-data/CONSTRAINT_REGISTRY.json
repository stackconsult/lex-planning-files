    {"table":"research_task_queries","name":"research_task_queries_task_id_fkey","columns":["task_id"],"references":"research_tasks","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
    {"table":"jurisdictions","name":"jurisdictions_tenant_id_fkey","columns":["tenant_id"],"references":"tenants","ref_columns":["id"],"on_delete":"CASCADE","on_update":"CASCADE"},
