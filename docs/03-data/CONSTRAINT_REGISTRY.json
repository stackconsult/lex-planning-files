  "not_null_constraints": {
    "policy": "All columns except notes, summaries, descriptions, optional metadata are NOT NULL",
    "exceptions": [
      "legal_documents.summary", "legal_documents.citation", "legal_documents.url", "legal_documents.version",
      "legal_documents.published_date", "legal_documents.last_modified",
      "legal_citations.citation_context", "legal_citations.location",
      "research_tasks.result_report", "research_tasks.confidence", "research_tasks.gaps",
      "research_tasks.started_at", "research_tasks.completed_at",
      "invention_candidates.novelty_score", "invention_candidates.nonobviousness_score",
      "invention_candidates.utility_score", "invention_candidates.enablement_score",
      "invention_candidates.scope_score", "invention_candidates.evidence_score",
      "invention_candidates.composite_score", "invention_candidates.scored_at",
      "disclosures.abstract", "disclosures.background", "disclosures.summary",
      "disclosures.detailed_description", "disclosures.claims", "disclosures.drawings_description",
      "disclosures.abstract_of_invention", "disclosures.advantages",
      "disclosures.alternative_implementations", "disclosures.example",
      "disclosures.prior_art_summary", "disclosures.references",
      "disclosures.grounding_sources", "disclosures.additional_materials",
      "disclosures.grounding_score",
      "prior_art.patent_number", "prior_art.authors", "prior_art.url",
      "prior_art.abstract", "prior_art.relevance_summary", "prior_art.relevance_score",
      "prior_art.published_date",
      "blockchain_anchors.bundle_hash", "blockchain_anchors.polygon_block_number",
      "blockchain_anchors.polygon_tx_timestamp",
      "filing_bundles.package_url", "filing_bundles.package_size_mb",
      "attorney_reviews.attorney_name", "attorney_reviews.review_notes",
      "attorney_reviews.rejection_reason", "attorney_reviews.request_changes_details",
      "attorney_reviews.portal_url", "attorney_reviews.reviewed_at"
    ]
  },
  "rls_policies": {
    "activation": "FORCE ROW LEVEL SECURITY",
    "default_policy_template": "CREATE POLICY {table}_tenant_isolation ON {table} FOR ALL TO app_role USING (tenant_id = current_setting('app.tenant_id')::UUID);",
    "tables_with_rls": [
      "tenants","users","roles_permissions","payment_plans","workspaces","api_keys","audit_log",
      "legal_documents","legal_chunks","legal_citations","query_cache","monitor_rules","monitor_alerts",
      "research_tasks","research_task_documents","research_task_citations","research_task_queries",
      "jurisdictions","invention_candidates","disclosures","prior_art","blockchain_anchors",
      "filing_bundles","disclosures_filing_bundles","attorney_reviews"
    ],
    "special_policies": {
      "tenants": "Users can only access their own tenant record",
      "audit_log": "Append-only — no UPDATE or DELETE allowed for all roles",
      "api_keys": "Only admin role can view/create API keys within tenant"
    }
  },
  "cascade_rules_summary": {
    "CASCADE": "Deleting a tenant or parent record deletes all dependent records automatically",
    "SET_NULL": "Used only for monitor_alerts.document_id (document may be deleted independently of alert)",
    "NO_ACTION": "Not used — all FKs use CASCADE for tenant-scoped tables"
  }
}
