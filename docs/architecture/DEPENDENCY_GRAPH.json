  "agent_dependencies": {
    "AGT_ROUTER": {
      "inputs": ["BAM compound from query"],
      "outputs": ["Agent dispatch decision"],
      "depends_on": [],
      "description": "Entry point — no dependencies"
    },
    "AGT_SEARCH": {
      "inputs": ["Query text", "BAM compound"],
      "outputs": ["Ranked document list", "Cache key"],
      "depends_on": ["AGT_ROUTER"],
      "description": "Receives dispatch from router"
    },
    "AGT_ANALYSIS": {
      "inputs": ["Research question", "Document corpus"],
      "outputs": ["Structured report", "Citation chain"],
      "depends_on": ["AGT_SEARCH", "AGT_CITE"],
      "description": "Uses search results and citation graph"
    },
    "AGT_DRAFT": {
      "inputs": ["Document template", "Evidence corpus"],
      "outputs": ["Draft document"],
      "depends_on": ["AGT_SEARCH"],
      "description": "Uses search results for drafting"
    },
    "AGT_INGEST": {
      "inputs": ["Raw document", "Source metadata"],
      "outputs": ["Parsed document", "Chunks", "Embeddings"],
      "depends_on": [],
      "description": "Independent — triggered by connectors"
    },
    "AGT_MONITOR": {
      "inputs": ["Monitor rules", "Legislative feed"],
      "outputs": ["Change alerts", "Updated documents"],
      "depends_on": ["AGT_INGEST"],
      "description": "Triggers ingest for new/updated documents"
    },
    "AGT_CITE": {
      "inputs": ["Document ID", "Citation direction"],
      "outputs": ["Citation graph", "Authority chain"],
      "depends_on": ["AGT_INGEST"],
      "description": "Requires ingested documents"
    },
    "AGT_SCANNER": {
      "inputs": ["GitHub/Jira/Notion webhooks"],
      "outputs": ["Invention signals"],
      "depends_on": [],
      "description": "Independent — triggered by webhooks"
    },
    "AGT_SIGNAL_CLASSIFIER": {
      "inputs": ["Invention signals"],
      "outputs": ["Classified signals", "Invention candidates"],
      "depends_on": ["AGT_SCANNER"],
      "description": "Processes scanner output"
    },
    "AGT_PRIORART": {
      "inputs": ["Invention candidate", "Search keywords"],
      "outputs": ["Prior art results", "Relevance scores"],
      "depends_on": ["AGT_SIGNAL_CLASSIFIER"],
      "description": "Searches for prior art on candidates"
    },
    "AGT_SCORER": {
      "inputs": ["Invention candidate", "Prior art results"],
      "outputs": ["6-dimension scores", "Composite score"],
      "depends_on": ["AGT_PRIORART", "AGT_SIGNAL_CLASSIFIER"],
      "description": "Scores after prior art search"
    },
    "AGT_DISCLOSER": {
      "inputs": ["Invention candidate", "Prior art", "Scores"],
      "outputs": ["10-section disclosure draft"],
      "depends_on": ["AGT_SCORER", "AGT_PRIORART"],
      "description": "Generates disclosure after scoring"
    },
    "AGT_LEDGER": {
      "inputs": ["Disclosure draft", "Filing bundle"],
      "outputs": ["Blockchain tx hash", "Proof certificate"],
      "depends_on": ["AGT_DISCLOSER"],
      "description": "Anchors after disclosure finalized"
    },
    "AGT_ATTYFLOW": {
      "inputs": ["Handoff package", "Attorney email"],
      "outputs": ["Scoped JWT", "Portal link", "Notification"],
      "depends_on": ["AGT_LEDGER"],
      "description": "Handoff after ledger anchoring"
    }
  },
  "critical_path": [
    "L0_sources",
    "L1_connectors",
    "L2_storage",
    "L3_services",
    "L4_api",
    "L5_frontend"
  ],
  "cycle_check": {
